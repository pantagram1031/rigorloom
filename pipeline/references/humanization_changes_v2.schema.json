{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "report-pipeline/humanization-changes-v2",
  "title": "Rigorloom humanization changes v2",
  "type": "object",
  "required": ["schema", "gate", "changes"],
  "properties": {
    "schema": {"const": "report-pipeline/humanization-changes-v2"},
    "gate": {
      "type": "object",
      "required": ["verdict", "skipped"],
      "properties": {
        "verdict": {"enum": ["PASS", "REWORK"]},
        "skipped": {"type": "boolean"},
        "advisory_score": {"type": ["number", "null"]}
      },
      "additionalProperties": true
    },
    "strength": {"enum": ["light", "standard", "strong"]},
    "round": {"type": "integer", "minimum": 1, "maximum": 3},
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["paragraph_id", "before", "after", "reviewer_verdict"],
        "properties": {
          "paragraph_id": {"type": "string", "pattern": "^p[0-9]{4,}$"},
          "section": {"enum": ["motivation", "theory", "method", "results", "conclusion", "body"]},
          "detected_patterns": {"type": "array", "items": {"type": "string"}},
          "severity": {"enum": ["low", "med", "high"]},
          "protected_spans": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["text", "type"],
              "properties": {"text": {"type": "string"}, "type": {"type": "string"}},
              "additionalProperties": false
            }
          },
          "academic_level_risk": {"enum": ["none", "low", "high"]},
          "style_profile_rules": {"type": "array", "items": {"type": "string"}},
          "before": {"type": "string"},
          "after": {"type": "string"},
          "alternative_candidates": {"type": "array", "items": {"type": "string"}},
          "selection_reason": {"type": "string"},
          "fidelity_evidence": {"type": "object"},
          "reviewer_verdict": {"enum": ["accept", "rewrite", "rollback"]},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1}
        },
        "additionalProperties": true
      }
    },
    "extreme_hedge_warnings": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true,
  "allOf": [
    {
      "if": {
        "properties": {"gate": {"properties": {"skipped": {"const": true}}}}
      },
      "then": {
        "properties": {
          "gate": {"properties": {"verdict": {"const": "PASS"}}},
          "changes": {"maxItems": 0}
        }
      }
    }
  ]
}
